# Admin panel credentials — the password is stored as a SHA-256 hash so the
# plaintext is never committed to source or shipped in the production JS bundle.
# The username is optional; if unset, the login command skips the username check
# (any username is accepted) for backward compatibility.
#
# This gate is CLIENT-SIDE ONLY. It keeps your credentials out of the repo, but
# it is not real authentication — a static site cannot securely protect an admin
# area. For actual protection, put the admin editor behind a server/back end.
#
# Generate the password hash (note: no trailing newline):
#   printf '%s' 'your-password-here' | shasum -a 256 | cut -d ' ' -f1
# or with Node:
#   node -e "console.log(require('crypto').createHash('sha256').update('your-password-here').digest('hex'))"
#
# Copy this file to .env.local (which is gitignored) and set the values there.
# If REACT_APP_ADMIN_PASSWORD_HASH is unset, admin login is disabled (fails closed).
REACT_APP_ADMIN_USERNAME=
REACT_APP_ADMIN_PASSWORD_HASH=
